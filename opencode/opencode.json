{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llmproxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLM Proxy",
      "options": {
        "baseURL": "https://llmproxy.ai.orange",
        "apiKey": "{env:OPENAI_API_KEY}"
      },
      "models": {
        "vertex_ai/claude-haiku-4-5": {
          "name": "Claude Haiku 4.5 - rapide économique",
          "limit": { "output": 64000, "context": 200000 },
          "cost": { "input": 1, "output": 5 }
        },
        "vertex_ai/claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 - équilibré",
          "limit": { "output": 64000, "context": 200000 },
          "cost": { "input": 3, "output": 15 },
        },
        "vertex_ai/claude-opus-4-5": {
          "name": "Claude Opus 4.5 - puissant cher",
          "limit": { "output": 64000, "context": 200000 },
          "cost": { "input": 5, "output": 25 }
        },
        "vertex_ai/claude-opus-4-6": {
          "name": "Claude Opus 4.6 - puissant cher",
          "limit": { "output": 64000, "context": 200000 },
          "cost": { "input": 5, "output": 25 }
        },
        "vertex_ai/claude3.5-sonnet-v2": {
          "name": "Claude Sonnet 3.5",
          "limit": { "output": 8192, "context": 200000 }
        },
        "vertex_ai/gemini-2.0-flash": {
          "name": "Gemini 2 Flash",
          "limit": { "output": 8192, "context": 1048576 }
        },
        "openai/gpt-5.1-codex": {
          "name": "GPT 5.1 Codex - Pour la génération de code",
          "cost": { "input": 1.25, "output": 10 }
        },
        "openai/gpt-5.2-codex": {
          "name": "GPT 5.2 Codex - Pour la génération de code",
          "cost": { "input": 1.75, "output": 14 }
        }
      }
    },
    "llmproxy4code": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LLM Proxy 4 code (via la console)",
      "options": {
        "baseURL": "https://api.llmproxy-code.ai.orange"
      },
      "models": {
        "openai/gpt-5.1-codex": {
          "name": "GPT 5 1 Codex - Pour la génération de code",
        },
        "openai/gpt-5.1-codex-max": {
          "name": "GPT 5 1 Codex Max Pour la génération de code nécessitant plus de capacités",
        },
        "openai/gpt-5.2": {
          "name": "GPT 5 2 - Pour un usage général (chat, analyse)",
        },
        "openai/gpt-5.2-codex": {
          "name": "GPT 5 2 Codex - Pour la génération de code",
        },
        "openai/omni-moderation-latest": {
          "name": "Omni Moderation Latest - designed to detect harmful content",
        }
      }
    }
  },
  "model": "llmproxy/vertex_ai/gemini-2.0-flash",
  "lsp": {
    "markdown": {
      "disabled": false,
      "command": ["marksman", "server"],
      "extensions": [".md", ".markdown"]
    }
  },
  "command": {
    "daily_tip_opencode": {
      "template": "lis les fichiers @dotfiles/opencode/ et la doc context7 et propose moi une fiche conseil du jour sur une fonctionnalité d'opencode nouvelle ou importante et que je ne semble pas utiliser. Ecris en Français.",
      "description": "Conseil du jour sur opencode",
      "agent": "plan",
      "model": "llmproxy/vertex_ai/claude-opus-4-5"
    },
    "daily_tip_kodi": {
      "template": " propose moi une fiche conseil du jour sur une fonctionnalité de kodi nouvelle ou importante et que je ne semble pas utiliser. Ecris en Français.",
      "description": "Conseil du jour sur opencode",
      "agent": "plan",
      "model": "llmproxy/vertex_ai/claude-opus-4-5"
    }
  }
}
